        "datasource": { "type": "postgres", "uid": "PAF660F95C478FB94" },
        "rawSql": "SELECT attack_type as \"Type\", cnt as \"Total\" FROM mv_attack_distribution WHERE attack_type NOT IN ('BENIGN','Normal','Attack') LIMIT 10",
