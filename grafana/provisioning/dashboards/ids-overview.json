    {
      "title": "Volume Trafic par Heure (Min/Max/Moy)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "PAF660F95C478FB94" },
        "rawSql": "SELECT date_trunc('hour', timestamp) as time, AVG(total_packets) as \"Moyen\", MAX(total_packets) as \"Max\", MIN(total_packets) as \"Min\" FROM traffic_stats GROUP BY date_trunc('hour', timestamp) ORDER BY time",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 20,
            "drawStyle": "line",
            "lineWidth": 2
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Max" }, "properties": [{ "id": "color", "value": { "fixed": "#ef4444" } }, { "id": "custom.fillOpacity", "value": 5 }, { "id": "custom.lineStyle", "value": { "fill": "dash" } }] },
          { "matcher": { "id": "byName", "options": "Min" }, "properties": [{ "id": "color", "value": { "fixed": "#22c55e" } }, { "id": "custom.fillOpacity", "value": 5 }, { "id": "custom.lineStyle", "value": { "fill": "dash" } }] },
          { "matcher": { "id": "byName", "options": "Moyen" }, "properties": [{ "id": "color", "value": { "fixed": "#3b82f6" } }, { "id": "custom.lineWidth", "value": 3 }] }
        ]
      },
