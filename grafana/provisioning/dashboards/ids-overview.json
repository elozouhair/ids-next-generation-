    },
    {
      "title": "Geo Localisation des Attaques",
      "type": "geomap",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 4 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "PAF660F95C478FB94" },
        "rawSql": "SELECT latitude, longitude, src_ip, attack_type, severity FROM attacks_geo WHERE latitude IS NOT NULL AND longitude IS NOT NULL AND attack_type NOT IN ('BENIGN','Normal','Attack') ORDER BY timestamp DESC LIMIT 1000",
        "format": "table"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "mapCenter": { "lat": 30, "lng": 0, "zoom": 1 },
        "showLegend": true,
        "tooltip": true,
        "controls": { "showZoom": true, "showAttribution": false }
      }
    },
    {
      "title": "Repartition CICIDS2017",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
