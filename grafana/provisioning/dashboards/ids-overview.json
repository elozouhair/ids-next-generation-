          { "matcher": { "id": "byName", "options": "Brute Force" }, "properties": [{ "id": "color", "value": { "fixed": "#845ef7" } }] },
          { "matcher": { "id": "byName", "options": "DDoS" }, "properties": [{ "id": "color", "value": { "fixed": "#339af0" } }] },
          { "matcher": { "id": "byName", "options": "Bot" }, "properties": [{ "id": "color", "value": { "fixed": "#20c997" } }] },
          { "matcher": { "id": "byName", "options": "Web Attack" }, "properties": [{ "id": "color", "value": { "fixed": "#f06595" } }] },
          { "matcher": { "id": "byName", "options": "SQL Injection" }, "properties": [{ "id": "color", "value": { "fixed": "#cc5de8" } }] },
          { "matcher": { "id": "byName", "options": "XSS" }, "properties": [{ "id": "color", "value": { "fixed": "#fab005" } }] },
          { "matcher": { "id": "byName", "options": "MITM" }, "properties": [{ "id": "color", "value": { "fixed": "#e64980" } }] }
        ]
      },
      "options": {
        "reduceOptions": { "values": true, "calcs": ["lastNotNull"], "fields": "/^Total$/" },
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent", "name"] },
        "pieType": "donut",
        "tooltip": { "mode": "single" }
      }
