    {
      "title": "Trafic : Attaques vs Normal (Temps Reel)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "PAF660F95C478FB94" },
        "rawSql": "SELECT timestamp as time, attack_count as \"Attaques\", normal_count as \"Normal\" FROM traffic_stats ORDER BY timestamp",
        "format": "time_series"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "fillOpacity": 30,
            "drawStyle": "line",
            "lineWidth": 1
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Attaques" }, "properties": [{ "id": "color", "value": { "fixed": "#ef4444" } }] },
          { "matcher": { "id": "byName", "options": "Normal" }, "properties": [{ "id": "color", "value": { "fixed": "#3b82f6" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] },
        "tooltip": { "mode": "multi" }
