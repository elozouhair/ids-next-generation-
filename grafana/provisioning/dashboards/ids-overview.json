    {
      "title": "Performance Modele ML",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 28 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "PAF660F95C478FB94" },
