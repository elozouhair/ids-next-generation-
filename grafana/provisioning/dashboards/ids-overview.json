      "title": "Alertes Recentes Temps Reel",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 29 },
      "targets": [{
        "datasource": { "type": "postgres", "uid": "PAF660F95C478FB94" },
        "rawSql": "SELECT timestamp as \"horodatage\", attack_type as \"type attaque\", src_ip as \"ip source\", dst_ip as \"ip dest\", protocol as \"proto\", severity as \"severite\" FROM alerts ORDER BY timestamp DESC LIMIT 25",
